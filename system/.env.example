# 오당역 — 환경변수 예시
# 실제 값은 system/.env 에 복사 후 채워서 사용 (git-ignored)

# 필수 — GPT-4o-mini, OpenAI TTS, DALL-E
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 선택 — DALL-E 실패 시 Replicate(Flux-schnell) 폴백
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxx

# 선택 — YouTube Data API (통계 조회용, 업로드는 OAuth 토큰 사용)
YOUTUBE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxx

# YouTube 업로드 OAuth 토큰 — 로컬: youtube_token_odangyeok.json / CI: secret 환경변수 YOUTUBE_TOKEN_ODANGYEOK (raw JSON)
